{
  "expo": {
    "name": "Solvr",
    "slug": "solvr-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "solvr",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solvr.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Solvr uses your microphone to record job details for voice-to-quote generation.",
        "NSPhotoLibraryUsageDescription": "Solvr needs access to your photo library so you can attach photos to your quotes.",
        "NSPhotoLibraryAddUsageDescription": "Solvr needs permission to save generated quote PDFs to your photo library.",
        "NSCameraUsageDescription": "Solvr uses the camera so you can take photos of job sites to attach to quotes.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.solvr.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://solvr.com.au"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F5A623",
          "defaultChannel": "default",
          "sounds": [],
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Solvr needs access to your photo library so you can attach photos to your quotes.",
          "cameraPermission": "Solvr uses the camera so you can take photos of job sites to attach to quotes."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Solvr uses your microphone to record job details for voice-to-quote generation."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": "https://solvr.com.au"
      },
      "eas": {
        "projectId": "85aaa191-4fb0-49a3-b520-c5417145fd0c"
      }
    },
    "owner": "solvr",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/85aaa191-4fb0-49a3-b520-c5417145fd0c"
    }
  }
}
